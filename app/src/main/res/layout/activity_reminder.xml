<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/background_light">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Payment Reminders"
        android:textColor="@color/blue_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtReminderTitle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Reminder title"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/edtReminderDate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Due date YYYY-MM-DD" />

    <EditText
        android:id="@+id/edtReminderNote"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Note" />

    <Button
        android:id="@+id/btnSaveReminder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save Reminder" />

    <ListView
        android:id="@+id/listReminders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />

</LinearLayout>